# Copy to .env and fill in. All keys are optional, but:
#   - GITHUB_TOKEN lifts API rate limits and unlocks private repos
#   - An AI key (Anthropic OR OpenRouter) enables the AI features (chat / summary / issues)

GITHUB_TOKEN=

# --- AI provider: pick ONE ---
# Option A: Anthropic directly
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Option B: OpenRouter (OpenAI-compatible). If set, takes precedence over Anthropic.
# Model is an OpenRouter slug, e.g. anthropic/claude-sonnet-4.5, openai/gpt-4o, google/gemini-2.0-flash-001
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional overrides
MAX_FILE_BYTES=1000000
